/repeat
/config.yml
/subscriptions.opml
/content/
/media/
/cache/
/state/
/admin/dist/*
# .keep stays committed so `go build` works on a fresh checkout that
# hasn't run `npm run build` yet — the embed directive needs at least
# one file in admin/dist to succeed.
!/admin/dist/.keep
/admin/node_modules/
*.bak
.DS_Store

# Dev compose runtime state (configs and OPML files stay tracked).
/dev/*/content/posts/*
/dev/*/content/drafts/*
/dev/*/media/*
/dev/*/cache/*
/dev/*/state/*
!/dev/*/content/posts/.keep
!/dev/*/content/drafts/.keep
