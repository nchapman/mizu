{% for p in posts %}
<article>
  <time datetime="{{ p.Date | iso8601 | escape }}">{{ p.Date | date: "%b %-d, %Y" }}</time>
  {% if p.Title != "" %}<h2><a href="{{ p.Path | escape }}">{{ p.Title | escape }}</a></h2>{% endif %}
  <div class="body">{{ p.HTML }}</div>
  {% if p.Title == "" %}<a class="permalink" href="{{ p.Path | escape }}">permalink</a>{% endif %}
</article>
{% else %}
<p>No posts yet.</p>
{% endfor %}
{% comment %}prev_url / next_url are omitted (not empty) when absent —
empty strings are truthy in Liquid, so don't "fix" the Go side to set
them to "" or these {% if %} guards stop working.{% endcomment %}
{% if pagination.total_pages > 1 %}
<nav class="pagination" aria-label="Pagination">
  {% if pagination.prev_url %}<a rel="prev" href="{{ pagination.prev_url | escape }}">← newer</a>{% endif %}
  <span>page {{ pagination.page }} of {{ pagination.total_pages }}</span>
  {% if pagination.next_url %}<a rel="next" href="{{ pagination.next_url | escape }}">older →</a>{% endif %}
</nav>
{% endif %}
