<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ page_title | default: site.Title | escape }}</title>
<meta name="viewport" content="width=device-width,initial-scale=1">
<link rel="alternate" type="application/rss+xml" title="{{ site.Title | escape }}" href="/feed.xml">
<link rel="webmention" href="/webmention">
<style>
body { font: 16px/1.6 system-ui, sans-serif; max-width: 640px; margin: 2em auto; padding: 0 1em; color: #222; }
header { border-bottom: 1px solid #eee; padding-bottom: 1em; margin-bottom: 2em; }
header h1 { margin: 0; font-size: 1.4em; }
header h1 a { color: inherit; text-decoration: none; }
article { margin-bottom: 2.5em; }
article time { color: #888; font-size: .85em; }
article h2 { margin: .2em 0; font-size: 1.2em; }
article h2 a { color: inherit; text-decoration: none; }
article .body img { max-width: 100%; }
footer { margin-top: 4em; padding-top: 1em; border-top: 1px solid #eee; color: #888; font-size: .85em; }
</style>
</head>
<body>
<header>
  <h1><a href="/">{{ site.Title | escape }}</a></h1>
</header>
<main>{{ content_for_layout }}</main>
<footer>
  by {{ site.Author | escape }} · <a href="/feed.xml">rss</a>
</footer>
</body>
</html>
