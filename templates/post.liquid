<article>
  <time datetime="{{ post.Date | iso8601 | escape }}">{{ post.Date | date: "%b %-d, %Y"}}</time>
  {% if post.Title %}<h2>{{ post.Title | escape }}</h2>{% endif %}
  <div class="body">{{ post.HTML }}</div>
</article>
{% if mentions %}
<section class="mentions">
  <h3>Mentions</h3>
  <ul>
    {% for m in mentions %}
    <li><a href="{{ m.Source | escape }}" rel="nofollow ugc">{{ m.Source | host_of | escape }}</a>
      <time datetime="{{ m.VerifiedAt | iso8601 | escape }}">{{ m.VerifiedAt | date: "%b %-d, %Y"}}</time></li>
    {% endfor %}
  </ul>
</section>
{% endif %}
